{
  "kind": "collectionType",
  "collectionName": "crash_themes",
  "info": {
    "singularName": "crash-theme",
    "pluralName": "crash-themes",
    "displayName": "Crash Theme"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "seo": {
      "type": "component",
      "component": "seo.seo",
      "repeatable": false
    },
    "faqs": {
      "type": "component",
      "component": "faqs.faqs",
      "repeatable": true
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "crash_themes"
    },
    "dynamicContent": {
      "type": "dynamiczone",
      "components": [
        "common.paragraph",
        "common.table",
        "common.figure",
        "common.svelte-component",
        "common.paragraph-with-figure"
      ]
    },
    "iconId": {
      "type": "string"
    },
    "crashes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::crash.crash",
      "mappedBy": "crashThemes"
    }
  }
}
